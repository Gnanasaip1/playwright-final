{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "types": ["node"],
    "strict": false,
    "skipLibCheck": true
  },
  "include": [
    "**/*.ts",
    "test-data/**/*.json"
  ]
}